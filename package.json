{
  "name": "frameforge-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source browser-native agentic video editor",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/editor.ts"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "agent:dev": "python3 backend/app.py",
    "dev:all": "npm run agent:dev & npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.409",
    "@remotion/cli": "4.0.409",
    "@remotion/player": "4.0.409",
    "@remotion/renderer": "4.0.409",
    "date-fns": "^4.1.0",
    "immer": "^10.0.0",
    "lucide-react": "^0.554.0",
    "next": "^16.1.3",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remotion": "4.0.409",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.0.17"
  },
